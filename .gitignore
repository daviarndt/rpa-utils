# OS files
.DS_Store
Thumbs.db
desktop.ini

# .NET build output
bin/
obj/
*.user
*.suo

# Compiled binaries (source + build scripts are committed; rebuild locally)
*.dll
*.pdb

# Exception: prebuilt release binaries shipped on purpose for locked-down
# environments that cannot fetch dependencies. Source + build script still ship too.
!dotnet-wrappers/pdfpig-reader/dist/
!dotnet-wrappers/pdfpig-reader/dist/*.dll

# NuGet / package download artifacts
*.nupkg
packages/

# Editor / IDE
.vs/
.vscode/
.idea/

# Logs and temp
*.log
*.tmp
gpresult.html
output.html
